{
	"name": "rojo-utils",
	"$schema": "../../node_modules/nx/schemas/project-schema.json",
	"projectType": "library",
	"tags": ["scope:tooling", "type:lib"],
	"targets": {
		"build": {
			"command": "tsdown",
			"outputs": ["{projectRoot}/dist"],
			"options": {
				"cwd": "libs/rojo-utils"
			}
		},
		"lint": {
			"command": "eslint",
			"hasTypeAwareRules": true
		},
		"test": {
			"command": "vitest run --coverage",
			"options": {
				"cwd": "libs/rojo-utils"
			}
		}
	}
}
