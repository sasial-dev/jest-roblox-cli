{
	"name": "spike-mega",
	"tree": {
		"$className": "DataModel",
		"ServerScriptService": {
			"$className": "ServerScriptService",
			"$properties": {
				"LoadStringEnabled": true
			}
		},
		"ReplicatedStorage": {
			"$className": "ReplicatedStorage",
			"DevPackages": {
				"$className": "Folder",
				"JestUtils": {
					"$path": "../ParalovPackages/jest-utils/default.project.json"
				}
			},
			"Test": {
				"$path": "../modules/jest/Packages"
			}
		},
		"ServerStorage": {
			"$className": "ServerStorage",
			"__pkg_stage": {
				"$className": "Folder",
				"friends": {
					"$path": "../ParalovPackages/friends-package/development.project.json"
				},
				"data": {
					"$path": "../ParalovPackages/data-package/development.project.json"
				},
				"uuid-generator": {
					"$path": "../ParalovPackages/uuid-generator/default.project.json"
				}
			}
		}
	}
}
