{
	"extends": "@isentinel/tsconfig/typescript",
	"compilerOptions": {
		"composite": true,
		"tsBuildInfoFile": "dist/tsconfig.lib.tsbuildinfo",
		"lib": ["esnext"],
		"libReplacement": true,
		"allowImportingTsExtensions": true,
		"allowJs": false,
		"emitDeclarationOnly": true,
		"noEmit": false,
		"outDir": "out",
		"isolatedDeclarations": true
	},
	"references": [
		{
			"path": "packages/luau-ast/tsconfig.lib.json"
		},
		{
			"path": "packages/rojo-utils/tsconfig.lib.json"
		},
		{
			"path": "packages/roblox-runner/tsconfig.lib.json"
		}
	],
	"include": ["src/**/*.ts", "types/**/*.d.ts", "package.json"],
	"exclude": ["vitest.config.ts", "src/**/*.spec.ts", "src/**/*.spec.tsx", "src/**/*.spec.jsx"]
}
