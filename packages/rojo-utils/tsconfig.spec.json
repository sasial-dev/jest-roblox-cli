{
	"extends": "@isentinel/tsconfig/typescript",
	"compilerOptions": {
		"composite": true,
		"lib": ["esnext"],
		"libReplacement": true,
		"allowImportingTsExtensions": true,
		"emitDeclarationOnly": true,
		"noEmit": false,
		"outDir": "./out-tsc/vitest"
	},
	"references": [
		{
			"path": "./tsconfig.lib.json"
		}
	],
	"include": [
		"eslint.config.ts",
		"vitest.config.ts",
		"tsdown.config.ts",
		"package.json",
		"src/**/*.spec.ts",
		"src/**/*.spec-d.ts",
		"test/**/*.ts",
		"test/**/*.d.ts"
	]
}
